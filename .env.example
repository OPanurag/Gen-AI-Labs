# Copy to .env and fill in your values.
# For local/dev: set GEMINI_API_KEY to use your own Gemini API (no OpenRouter needed).
# For production: set OPENROUTER_API_KEY (GEMINI_API_KEY is ignored when OpenRouter is used).

# Optional. When set, Gemini is used for all LLM calls (local/dev).
# Get a key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Optional. Gemini model when using GEMINI_API_KEY (default: gemini-2.0-flash).
# GEMINI_MODEL=gemini-2.5-flash

# Required when GEMINI_API_KEY is not set (production). Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=

# Optional. Shared model for OpenRouter (default: openrouter/free).
# OPENROUTER_MODEL=openrouter/free
