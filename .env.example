# Copy to .env and fill in your values.
# All env vars used by the project are listed here.

# OpenRouter API key (required for pipeline and public tests)
# Get one at https://openrouter.ai/
OPENROUTER_API_KEY=

# Optional: LLM model override (default: openai/gpt-5-nano)
# OPENROUTER_MODEL=openai/gpt-5-nano
