# Copy to .env and fill in your values.
# OpenRouter only: API key and (optional) shared model for all requests.

OPENROUTER_API_KEY=

# Optional. Shared model for all LLM requests (default: openrouter/free).
# Examples: qwen/qwen3-coder:free | openrouter/free | openai/gpt-oss-120b:free
# OPENROUTER_MODEL=openrouter/free
